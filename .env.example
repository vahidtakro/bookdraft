# SerpApi (get free key at https://serpapi.com - 250 free searches/month)
SERPAPI_KEY=your_serpapi_key_here

# BscScan API (get free key at https://bscscan.com/myapikey)
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Your USDT BEP20 wallet address
WALLET_ADDRESS=0xYourWalletAddressHere

# Public wallet address (shown to users in the UI)
PUBLIC_WALLET_ADDRESS=0xYourWalletAddressHere
